generator client {
  provider = "prisma-client-js"
}

// LOCAL DEVELOPMENT: Uses SQLite
// FOR VERCEL DEPLOYMENT: Switch to PostgreSQL by:
// 1. Change provider to "postgresql"
// 2. Set DATABASE_URL to your PostgreSQL connection string (Neon, Vercel Postgres, etc.)
// 3. Add directUrl for connection pooling if using Neon
// 4. Run: npx prisma db push
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  username      String?
  avatarUrl     String?
  xUserId       String?
  xUsername     String?
  // X API v2 OAuth 2.0 tokens (encrypted at rest)
  xOAuth2AccessToken  String?
  xOAuth2RefreshToken String?
  xOAuth2ExpiresAt    DateTime?
  // Twikit cookies (encrypted at rest)
  xAccessToken  String?   // auth_token for Twikit
  xCookies      String?   // JSON: encrypted Twitter cookies (auth_token, ct0, etc.)
  xConnected    Boolean   @default(false)
  xAuthMethod   String    @default("none") // 'x_api' | 'twikit' | 'auto' | 'none'
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bookmarks   Bookmark[]
  collections Collection[]
  sessions    Session[]
  activities  Activity[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Collection {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  coverUrl    String?
  color       String?
  icon        String?
  isSmart     Boolean  @default(false)
  smartQuery  String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookmarks Bookmark[]
  tags      Tag[]
}

model Bookmark {
  id              String   @id @default(cuid())
  userId          String
  xPostId         String
  xAuthorId       String?
  xAuthorName     String?
  xAuthorUsername String?
  xAuthorAvatar   String?
  content         String
  mediaUrls       String   @default("[]") // JSON array of URLs
  mediaTypes      String   @default("[]") // JSON array: photo, video, gif
  replyCount      Int      @default(0)
  repostCount     Int      @default(0)
  likeCount       Int      @default(0)
  viewCount       Int      @default(0)
  bookmarkCount   Int      @default(0)
  isBookmarked    Boolean  @default(true)
  source          String   @default("x_api") // 'x_api' | 'twikit'
  postedAt        DateTime?
  savedAt         DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  collections Collection[]
  tags        Tag[]
  aiSummary   String?

  @@unique([userId, xPostId])
}

model Tag {
  id          String   @id @default(cuid())
  userId      String
  name        String
  color       String?
  createdAt   DateTime @default(now())

  collections Collection[]
  bookmarks   Bookmark[]

  @@unique([userId, name])
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  type      String   // bookmark_save, collection_create, sync_complete, twitter_connect, etc.
  metadata  String   @default("{}") // JSON
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SyncStatus {
  id             String   @id @default(cuid())
  userId         String   @unique
  lastSyncAt     DateTime @default(now())
  lastBookmarkId String?
  isSyncing      Boolean  @default(false)
  syncCount      Int      @default(0)
  errorCount     Int      @default(0)
  lastError      String?
  provider       String   @default("auto") // 'x_api' | 'twikit' | 'auto'
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// OAuth 2.0 PKCE state — stored in DB so it survives cross-domain redirects
// (cookies get lost when the app runs in a preview iframe on a different domain
//  than the OAuth callback URL)
model OAuthState {
  id            String   @id @default(cuid())
  state         String   @unique
  codeVerifier  String
  userId        String
  redirectUri   String
  createdAt     DateTime @default(now())
  expiresAt     DateTime // auto-cleaned after 10 minutes
}
